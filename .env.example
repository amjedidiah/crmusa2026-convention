# Copy to `.env.local` for local Vercel CLI / `vercel dev`, or set in the Vercel project dashboard.

# --- Supabase (required) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service_role...
# Required for staff routes: GET /auth/v1/user must use anon (same trust as admin-sync.html). Never rely on service_role here.
SUPABASE_ANON_KEY=eyJ...anon...
# Optional: override apikey for Auth verification only (rare). Do not use to “fix” missing anon with service_role.
# SUPABASE_AUTH_KEY=

# --- Transactional email ---
# Auto: Resend on Vercel production/preview, OR when RESEND_API_KEY is set (local `vercel dev` — avoids host SMTP to Docker Mailpit). Otherwise SMTP → Mailpit.
# Local `vercel dev` without Mailpit → ECONNREFUSED. With Supabase CLI + `SUPABASE_URL=http://127.0.0.1:54321`, SMTP defaults to **54325** (same Mailpit as Auth; UI http://127.0.0.1:54324). Standalone Mailpit is usually **1025** — set `MAILPIT_SMTP_PORT` if needed.
# Override: `resend` | `smtp` (Mailpit).
# EMAIL_TRANSPORT=smtp
# RESEND_API_KEY=re_...          # With key set, local `vercel dev` uses Resend automatically (no host Mailpit). Required on Vercel prod/preview.
# MAILPIT_SMTP_HOST=127.0.0.1    # optional; default 127.0.0.1
# MAILPIT_SMTP_PORT=54325      # optional; default 54325 when SUPABASE_URL is local :54321, else 1025

# --- Email (Resend) ---
RESEND_API_KEY=re_...

# --- Site & signed lookup links ---
SITE_URL=https://your-deployment.vercel.app
# Optional: staff magic-link return URL (must match Supabase Auth redirect allowlist). Defaults to SITE_URL + /admin-sync.html.
# STAFF_MAGIC_LINK_REDIRECT=https://preview.vercel.app/admin-sync.html
LOOKUP_TOKEN_SECRET=use-a-long-random-string-min-32-chars
# Optional: seconds until `/#return?token=...` expires (default 7 days; max 365 days). Invalid values fall back to default.
# LOOKUP_TOKEN_TTL_SECONDS=2592000

# --- Weekly reminders (`GET /api/remind`) ---
CRON_SECRET=another-long-random-secret

# --- Staff admin (comma- or newline-separated emails, lowercased when matched) ---
STAFF_EMAIL_ALLOWLIST=finance@example.org,ops@example.org

# CORS for /api/admin/* (never "*"). Comma/newline-separated origins that host admin-sync.
# If unset: uses STAFF_ORIGIN, else SITE_URL (same-deployment admin + API).
# STAFF_ORIGINS=https://your-deployment.vercel.app
# STAFF_ORIGIN=https://your-deployment.vercel.app

# --- Rate limits (optional; register + lookup-request skip limits if unset) ---
# UPSTASH_REDIS_REST_URL=https://....upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
